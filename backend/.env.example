# ---------------------
# 📦 Database Config
# ---------------------
POSTGRES_DB=office_db
POSTGRES_USER=officeuser
POSTGRES_PASSWORD=Cats@office2026
DATABASE_HOST=db
DATABASE_PORT=5431
DATABASE_URL=postgresql://officeuser:<put db password here>@db:5431/office_db

# ---------------------
# 🚀 Flask Config
# ---------------------
SECRET_KEY=<put flask secret key here>
FLASK_ENV=development

# ---------------------
# 👤 Admin Setup
# ---------------------
ADMIN_NAME=admin
ADMIN_EMAIL=info@cats-global.com
ADMIN_PASSWORD=Pa55@word

# ---------------------
# 📧 SMTP / Daily Report
# ---------------------
# Required to enable the daily attendance report email.
# The report is sent automatically at office end + 4 hours (e.g. 10:00 PM IST).
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_USE_TLS=true
# Comma-separated list of recipient emails
REPORT_RECIPIENTS=admin1@company.com,admin2@company.com

# ---------------------
# 📱 WhatsApp (Meta Cloud API)
# ---------------------
# Required to enable WhatsApp notifications for check-in/out, reports, etc.
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id
WHATSAPP_ACCESS_TOKEN=your-access-token
WHATSAPP_API_VERSION=v21.0
# Token used by Meta to verify webhook subscription (must match Meta's config)
WHATSAPP_WEBHOOK_VERIFY_TOKEN=smartattend_verify_token
